{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mission-control",
  "version": "0.1.0",
  "identifier": "com.missioncontrol.desktop",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:5199"
  },
  "app": {
    "windows": [
      {
        "title": "Mission Control",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5199; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' http://localhost:5199 blob: data:; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
